{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "routes": [
    { "src": "/health", "dest": "/api/health.py" },
    { "src": "/api/predict/upload", "dest": "/api/predict/upload.py" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ],
  "functions": {
    "api/**/*.py": {
      "maxDuration": 30,
      "excludeFiles": "{scripts/**,Results/plots_png/**,uploads/**,*.docx}"
    }
  }
}
